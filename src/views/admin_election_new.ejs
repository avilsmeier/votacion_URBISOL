<%- include('layout', { title: "Nueva campaña", body: `
  <div class="card">
    <div class="topbar">
      <h2>Nueva campaña</h2>
      <a href="/admin">Volver</a>
    </div>

    <p class="muted">
      Selecciona tipo de campaña y fecha/hora (hora Lima). No hace falta escribir formatos.
    </p>

    <form method="POST" action="/admin/elections/new">
      <label>Tipo de campaña</label>
      <select name="kind" required>
        <option value="ELECTION">Elección: Directiva + Fiscales</option>
        <option value="VOTACION">Votación interna / Referéndum</option>
      </select>

      <label>Título</label>
      <input name="title" required />

      <label>Registro abre</label>
      <input name="reg_open_at" type="datetime-local" required />

      <label>Registro cierra</label>
      <input name="reg_close_at" type="datetime-local" required />

      <label>Votación abre</label>
      <input name="vote_open_at" type="datetime-local" required />

      <label>Votación cierra</label>
      <input name="vote_close_at" type="datetime-local" required />

      <button class="ok" type="submit">Crear</button>
    </form>

    <hr/>
    <p class="muted">
      Para una votación interna, luego entra al panel y usa "Configurar votación" para cargar la pregunta y opciones.
    </p>
  </div>
` }) %>
