<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title><%= title || "Votación" %></title>
  <style>
    * { box-sizing: border-box; }
    body { font-family: system-ui, Arial; background:#f7f7f7; margin:0; color:#222; }
    .wrap { max-width: 760px; margin: 24px auto; padding: 0 12px; }
    .card { background:#fff; border:1px solid #ddd; border-radius: 12px; padding: 18px; box-shadow: 0 1px 2px rgba(0,0,0,.04); }
    label { display:block; margin-top: 12px; font-weight: 600; }
    input, select, button, textarea { width:100%; padding: 10px; border-radius:10px; border:1px solid #ccc; margin-top:6px; font: inherit; }
    button { cursor:pointer; font-weight:700; }
    button:disabled { opacity:.55; cursor:not-allowed; }
    .row { display:flex; gap:12px; align-items:flex-start; flex-wrap:wrap; }
    .row > * { flex:1 1 220px; min-width:0; }
    .form-grid { display:grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; align-items:start; }
    .form-grid .full { grid-column: 1 / -1; }
    .muted { color:#666; font-size: 14px; }
    .ok { background:#0a7; color:#fff; border:0; }
    .bad { background:#c33; color:#fff; border:0; }
    .secondary { background:#f2f2f2; color:#222; border:1px solid #ccc; }
    a { color:#06c; }
    .topbar { display:flex; justify-content:space-between; align-items:center; gap:12px; margin-bottom: 12px; flex-wrap:wrap; }
    .pill { padding:6px 10px; border-radius: 999px; background:#eee; font-size: 13px;}
    .admin-link { margin-top:12px; font-size:13px; text-align:right; }
    @media (max-width: 640px) {
      .wrap { margin: 12px auto; }
      .card { padding: 14px; }
      .row { display:block; }
      .row > * { margin-top: 8px; }
      .form-grid { grid-template-columns: 1fr; gap: 0; }
      .admin-link { text-align:left; }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <%- body %>
  </div>
</body>
</html>
